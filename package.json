{
  "name": "@minimal-kit/starter-next-js",
  "author": "Minimals",
  "version": "6.3.0",
  "description": "Next Starter & JavaScript",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "build": "next build --turbopack",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:print": "npx eslint --print-config eslint.config.mjs > eslint-show-config.json",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "fix:all": "npm run lint:fix && npm run fm:fix",
    "clean": "rm -rf node_modules .next out dist build",
    "re:dev": "yarn clean && yarn install && yarn dev",
    "re:build": "yarn clean && yarn install && yarn build",
    "re:build-npm": "npm run clean && npm install && npm run build"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/dm-sans": "^5.1.1",
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/nunito-sans": "^5.1.1",
    "@fontsource-variable/public-sans": "^5.1.2",
    "@fontsource/barlow": "^5.1.1",
    "@hcaptcha/react-hcaptcha": "^0.3.9",
    "@hookform/resolvers": "^3.9.1",
    "@iconify/react": "^5.1.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/lab": "^6.0.0-beta.21",
    "@mui/material": "^6.3.0",
    "@mui/material-nextjs": "^7.3.7",
    "@mui/x-charts": "^8.27.0",
    "@mui/x-data-grid": "^7.23.5",
    "@mui/x-date-pickers": "^7.29.4",
    "@mui/x-tree-view": "^7.23.2",
    "@tiptap/extension-code-block-lowlight": "^3.9.0",
    "@tiptap/extension-image": "^3.9.0",
    "@tiptap/extension-link": "^3.9.0",
    "@tiptap/extension-placeholder": "^3.9.0",
    "@tiptap/extension-text-align": "^3.9.0",
    "@tiptap/extension-underline": "^3.9.0",
    "@tiptap/react": "^3.9.0",
    "@tiptap/starter-kit": "^3.9.0",
    "altcha": "^2.2.4",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^1.12.2",
    "chart.js": "^4.5.1",
    "country-state-city": "^3.2.1",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.31.0",
    "framer-motion": "^11.15.0",
    "lowlight": "^3.3.0",
    "minimal-shared": "^1.0.5",
    "next": "^16.1.6",
    "nprogress": "^0.2.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-country-flag": "^3.1.0",
    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.54.2",
    "react-otp-input": "^3.1.1",
    "react-simple-maps": "^3.0.0",
    "react-toastify": "^11.0.5",
    "react-turnstile": "^1.1.3",
    "recharts": "^3.7.0",
    "simplebar-react": "^3.3.0",
    "slugify": "^1.6.6",
    "stylis": "^4.3.4",
